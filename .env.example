# ss-to-wp-worker env (Railway dashboard → Variables)
# Kopēt VĒRTĪBAS no sslv-ai-runner-railway/crm/.env tām pašām atslēgām.

# Railway Postgres (tas pats, ko crm)
DATABASE_URL=

# OpenAI — image_classify (gpt-4o-mini vision) + image_enhance_openai (gpt-image-1)
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_SIZE=1536x1024

# Replicate — image_pipeline (Seedream-5-lite, primārais lētais)
REPLICATE_API_TOKEN=

# WordPress — Houzez REST via mūsu plugin rgc-mk/v5
WP_URL=https://rgcommerce.lv
RGC_MK_TOKEN=                  # X-RGC-Token shared secret (plugin v5)

# Storage — Railway volume mount (inbox-to-listings-volume)
STORAGE_ROOT=/storage

# Opcionāli — SSL verify (Railway iekšā vienmēr 1)
VERIFY_SSL=1
